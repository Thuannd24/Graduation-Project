# =============================================================================
# E-commerce Backend - Environment Variables
# =============================================================================
# Copy file này thành .env và sửa theo môi trường của bạn
#   cp .env.example .env
#
# Dùng cho:
#   - Docker Compose: tự động đọc file .env
#   - IntelliJ: dùng plugin EnvFile hoặc set trong Run Configuration
#   - EC2: export các biến này trên EC2 instance
# =============================================================================

# ===== MariaDB =====
DB_HOST=localhost
DB_PORT=3308
DB_USER=root
DB_PASSWORD=root

# ===== MongoDB =====
MONGO_HOST=localhost
MONGO_PORT=27017

# ===== Redis =====
REDIS_HOST=localhost
REDIS_PORT=6379

# ===== Kafka =====
KAFKA_BOOTSTRAP_SERVERS=localhost:29092

# ===== Elasticsearch =====
ES_HOST=localhost
ES_PORT=9200

# ===== MinIO =====
MINIO_ENDPOINT=http://localhost:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=12345678a@
MINIO_BUCKET_NAME=product-images

# ===== Keycloak =====
KEYCLOAK_ISSUER_URI=http://localhost:8083/realms/ecommerce-realm
KEYCLOAK_SERVER_URL=http://localhost:8083
KEYCLOAK_ADMIN_URL=http://localhost:8083
KEYCLOAK_REALM=ecommerce-realm
KEYCLOAK_ADMIN_CLIENT_ID=ecommerce-backend
KEYCLOAK_ADMIN_CLIENT_SECRET=ZAyFzRoBJY8nWNg5dN5XMc3fRngDIei6

# ===== Eureka =====
EUREKA_HOST=localhost

# ===== Mail (Gmail SMTP) =====
