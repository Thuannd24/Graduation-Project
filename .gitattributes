# =============================================================================
# TECHSTORE ROOT .GITATTRIBUTES (QUẢN LÝ XUỐNG DÒNG CRLF/LF CHÉO NỀN TẢNG)
# =============================================================================

# Thiết lập mặc định tự động nhận diện file text
* text=auto

# Ép buộc tất cả file mã nguồn sử dụng LF (tránh lỗi xung đột giữa Windows & Linux Docker)
*.java       text eol=lf
*.js         text eol=lf
*.jsx        text eol=lf
*.ts         text eol=lf
*.tsx        text eol=lf
*.css        text eol=lf
*.html       text eol=lf
*.json       text eol=lf
*.xml        text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
*.properties text eol=lf
*.md         text eol=lf
*.env*       text eol=lf
Dockerfile   text eol=lf

# Đảm bảo các tệp tin script Shell luôn sử dụng LF (CRLF sẽ làm lỗi Bash trong Docker)
*.sh         text eol=lf
*.bash       text eol=lf

# Khai báo các file Nhị phân (Binary) - Không chỉnh sửa nội dung
*.jar        binary
*.war        binary
*.zip        binary
*.tar.gz     binary
*.png        binary
*.jpg        binary
*.jpeg       binary
*.gif        binary
*.ico        binary
*.pdf        binary
