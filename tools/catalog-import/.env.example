API_BASE_URL=http://localhost:8080/api/v1
# Token Keycloak admin — chỉ cần khi chạy --apply
ADMIN_TOKEN=

# Cloudflare R2 — dùng cho mirror-images.mjs (mirror ảnh sản phẩm khỏi phụ thuộc site nguồn)
# Lấy tại dash.cloudflare.com > R2 > Manage API tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Public bucket URL (R2 > bucket > Settings > Public access), không có dấu / ở cuối
R2_PUBLIC_URL_BASE=
