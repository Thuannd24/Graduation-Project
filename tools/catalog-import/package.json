{
  "name": "catalog-import",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Import catalog data into AuraTech product-service (dry-run by default)",
  "scripts": {
    "validate": "node import.mjs --file data/sample-manifest.json",
    "validate:100": "node import.mjs --file data/catalog-100.json",
    "generate:100": "node generate-realistic-catalog.mjs --count 100 --out data/catalog-100.json",
    "import": "node import.mjs --file data/sample-manifest.json --apply",
    "import:100": "node import.mjs --file data/catalog-100.json --apply",
    "generate": "node generate-manifest.mjs --count 200 --out data/generated-manifest.json",
    "csv": "node csv-to-manifest.mjs --dir templates/csv --out data/from-csv-manifest.json"
  }
}
