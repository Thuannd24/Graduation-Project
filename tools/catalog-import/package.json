{
  "name": "catalog-import",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Scrape, mirror ảnh lên R2, và import catalog vào AuraTech product-service",
  "scripts": {
    "setup": "node setup.mjs",
    "setup:dry-run": "node setup.mjs --dry-run",
